<?xml version="1.0" encoding="utf-8"?>
<!--
  Network security config для приложения.

  В Android 9+ (API 28+) cleartext HTTP запрещён по умолчанию.
  На dev-этапе используем HTTPS с self-signed сертификатом
  (см. `tool/certs/server.crt`, сгенерированный через
  PowerShell + openssl, с SAN: `quran-app.local`, `localhost`,
  `10.0.2.2`, `127.0.0.1`).

  `quran_app_local` в `res/raw/` — наш self-signed CA, добавлен
  в `trust-anchors` для dev-окружения. В проде этот блок
  удаляется, и остаётся только `system` trust.

  Продовые endpoint'ы (`api.alquran.cloud`, `quran-app.github.io`,
  `content.quran-app.com`) — только HTTPS с system trust anchors
  (Let's Encrypt / DigiCert).
-->
<network-security-config>
    <!--
        Base config: cleartext запрещён глобально (Android 9+ default).
        Self-signed cert из `res/raw/quran_app_local` добавлен как
        trusted только для разработки. В проде: удалить строку
        с `@raw/quran_app_local`, оставить только `system`.
    -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="@raw/quran_app_local" />
        </trust-anchors>
    </base-config>

    <!--
        Явный whitelist loopback'ов для legacy dev-сценариев
        (если кто-то предпочитает cleartext HTTP). Не
        используется в нашем HTTPS-pipeline'е, но оставлен
        для `flutter run` с cleartext http на 10.0.2.2.
    -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">quran-app.local</domain>
    </domain-config>
</network-security-config>
